{
	"$schema": "https://json.schemastore.org/tsconfig",
	"compilerOptions": {
		"baseUrl": ".",
		"jsx": "preserve",
		"paths": {
			"@/*": ["./src/*"]
		},
		"plugins": [{ "name": "next" }],
		"types": ["node"]
	},
	"exclude": ["node_modules"],
	"extends": "@rubriclab/config/tsconfig",
	"include": [
		"next-env.d.ts",
		".next/types/**/*.ts",
		"app/**/*.ts",
		"app/**/*.tsx",
		"src/**/*.ts",
		"src/**/*.tsx"
	]
}
