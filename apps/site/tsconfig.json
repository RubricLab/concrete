{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@concrete/ui": ["../../packages/ui/src/index.tsx"],
      "@concrete/ui/styles.css": ["../../packages/ui/src/styles.css"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "incremental": true,
    "noEmit": true
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
