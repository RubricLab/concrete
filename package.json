{
	"devDependencies": {
		"@biomejs/biome": "^2.3.8",
		"@rubriclab/config": "*",
		"@types/bun": "latest",
		"typescript": "^5.9.3"
	},
	"name": "concrete",
	"private": true,
	"scripts": {
		"audit:imports": "bun test packages/concrete/src/tests/import-boundaries.test.ts",
		"bleed": "bun x npm-check-updates -u",
		"build": "bun run build:package && bun run build:docs",
		"build:docs": "bun run --cwd apps/docs build",
		"build:package": "bun run --cwd packages/concrete build",
		"check": "bun run typecheck && bun run lint && bun test",
		"clean": "rm -rf node_modules apps/docs/.next packages/concrete/.tsbuildinfo",
		"dev": "bun run build:package && bun run --cwd apps/docs dev",
		"dev:docs": "bun run --cwd apps/docs dev",
		"format": "bun x biome check . --write",
		"lint": "bun x biome check .",
		"typecheck": "bun run --cwd packages/concrete typecheck && bun run --cwd apps/docs typecheck"
	},
	"workspaces": [
		"apps/*",
		"packages/*"
	]
}
